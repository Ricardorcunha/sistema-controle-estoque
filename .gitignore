# ============================================================
# .gitignore — Arquivos que NÃO devem ir para o repositório Git
# ============================================================

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
.eggs/
*.egg-link

# ------------------------------------------------------------
# Ambientes virtuais
# ------------------------------------------------------------
.env
.venv
env/
venv/
ENV/
.python-version

# ------------------------------------------------------------
# Django
# ------------------------------------------------------------
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
staticfiles/
media/

# ------------------------------------------------------------
# Testes e cobertura
# ------------------------------------------------------------
.coverage
.coverage.*
coverage.xml
*.cover
htmlcov/
.pytest_cache/
.tox/
nosetests.xml

# ------------------------------------------------------------
# IDEs e editores
# ------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db

# ------------------------------------------------------------
# Docker
# ------------------------------------------------------------
# (docker-compose.yml e Dockerfile SÃO versionados)
# Mas não versionar volumes locais se existirem

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
logs/
*.log

# ------------------------------------------------------------
# Variáveis de ambiente (NUNCA versionar o .env real!)
# O .env.example SIM deve ser versionado.
# ------------------------------------------------------------
.env
.env.local
.env.*.local

# ------------------------------------------------------------
# Pasta de rascunho (arquivos gerados, não versionar)
# ------------------------------------------------------------
rascunho/

# ------------------------------------------------------------
# Node / Frontend
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------------------------------------------
# Misc
# ------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
*.pem
