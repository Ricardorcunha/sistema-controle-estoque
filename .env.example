# ============================================================
# .env.example — Modelo de variáveis de ambiente
# ============================================================
# Copie este arquivo para .env e preencha com seus valores:
#   cp .env.example .env
#
# Este arquivo É versionado no Git (sem valores reais).

# ------------------------------------------------------------
# Django
# ------------------------------------------------------------
SECRET_KEY=gere-uma-chave-secreta-aqui
DJANGO_SETTINGS_MODULE=config.settings.development
DEBUG=True

# ------------------------------------------------------------
# Banco de dados PostgreSQL
# ------------------------------------------------------------
DB_NAME=estoque_db
DB_USER=estoque_user
DB_PASSWORD=sua-senha-aqui
DB_HOST=db
DB_PORT=5432

# ------------------------------------------------------------
# Email
# ------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=seu-email@gmail.com
EMAIL_HOST_PASSWORD=sua-senha-de-app
DEFAULT_FROM_EMAIL=noreply@estoque.com

# ------------------------------------------------------------
# Produção (preencher apenas no servidor de produção)
# ------------------------------------------------------------
ALLOWED_HOSTS=localhost,127.0.0.1
# Em produção real:
# ALLOWED_HOSTS=seudominio.com,www.seudominio.com
# CORS_ALLOWED_ORIGINS=https://seudominio.com
# SECURE_SSL_REDIRECT=True
